 min-height: 100vh;
 padding-top: 5rem;
 padding-bottom: 2rem;
 border-bottom: 1px solid var(, border-zinc);
 }

.legal-container {
 max-width: 44rem;
 }

.legal-back {
 font-size: 0.85rem;
 color: var(, text-zinc-500);
 text-decoration: none;
 display: inline-block;
 margin-bottom: 2rem;
 }

.legal-back:hover {
 color: var(, text-zinc-200);
 }

.legal-eyebrow {
 font-size: 0.75rem;
 font-weight: 600;
 text-transform: uppercase;
 letter-spacing: 0.08em;
 color: var(, text-zinc-500);
 margin: 0 0 0.75rem;
 }

.legal-hero h1 {
 font-size: clamp(1.75rem, 4vw, 2.25rem);
 margin: 0 0 1rem;
 }

.legal-lede {
 margin: 0 0 2.5rem;
 font-size: 0.95rem;
 }

.legal-body section {
 margin-bottom: 2rem;
 }

.legal-body h2 {
 font-size: 1.15rem;
 margin: 0 0 0.75rem;
 }

.legal-body h3 {
 font-size: 0.95rem;
 margin: 1.25rem 0 0.5rem;
 color: var(, text-zinc-50);
 }

.legal-body ul {
 margin: 0.5rem 0 0;
 padding-left: 1.25rem;
 }

.legal-body li {
 margin-bottom: 0.5rem;
 }

.legal-body a {
 color: var(, text-zinc-200);
 text-decoration: underline;
 text-underline-offset: 2px;
 }

.legal-body a:hover {
