---
import OpensInNewTab from "./OpensInNewTab.astro";
---
<section id="community" class="section community-section" aria-labelledby="community-heading">
  <div class="container">
    <div class="community-grid">
      <div class="community-intro">
        <h2 id="community-heading" class="section-title">An active lab for student creators</h2>
        <p class="community-desc">
          uplb.tools serves as a collaborative sandbox. We welcome all UPLB
          students interested in design, engineering, or documentation.
        </p>

        <ul class="roles-list">
          <li class="role-item card">
            <div class="role-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                stroke="currentColor"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="16 18 22 12 16 6"></polyline>
                <polyline points="8 6 2 12 8 18"></polyline>
              </svg>
            </div>
            <div class="role-text">
              <h3>Software engineering</h3>
              <p>
                Contribute to codebases built with Astro, React, and Vite. Learn
                clean repository architecture, Git flows, and review cycles.
              </p>
            </div>
          </li>

          <li class="role-item card">
            <div class="role-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                stroke="currentColor"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="9" y1="3" x2="9" y2="21"></line>
              </svg>
            </div>
            <div class="role-text">
              <h3>UI / UX design</h3>
              <p>
                Wireframe layouts, model workflows, and construct design tokens.
                Make tools responsive, accessible, and clean.
              </p>
            </div>
          </li>

          <li class="role-item card">
            <div class="role-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="16"
                height="16"
                stroke="currentColor"
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                ></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
              </svg>
            </div>
            <div class="role-text">
              <h3>Documentation and copy</h3>
              <p>
                Write setup guidelines, draft release logs, compile instructions,
                and explain how to install our browser extensions.
              </p>
            </div>
          </li>
        </ul>
      </div>

      <div class="community-links" aria-label="Join the community">
        <div class="card link-card">
          <h3>GitHub organization</h3>
          <p>
            Request an invitation to the organization, browse open issues, or
            review our pull requests.
          </p>
          <a
            href="https://github.com/uplbtools"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            Explore on GitHub
            <OpensInNewTab />
          </a>
        </div>

        <div class="card link-card">
          <h3>Discord server</h3>
          <p>
            Join chats to brainstorm ideas, ask technical questions, and
            coordinate code modifications.
          </p>
          <a
            href="https://discord.uplbtools.me"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary"
          >
            Join Discord
            <OpensInNewTab />
          </a>
        </div>

        <div class="card link-card">
          <h3>Messenger GC</h3>
          <p>
            Informal coordinator chat for UPLB organization members to host quick
            standups.
          </p>
          <a
            href="https://messenger.uplbtools.me"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary"
          >
            Join Messenger GC
            <OpensInNewTab />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .community-section {
    background: linear-gradient(
      180deg,
      var(--bg-page) 0%,
      hsl(5, 18%, 94%) 100%
    );
    border-bottom: none;
  }

  .community-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2.5rem;
    align-items: start;
  }

  .community-intro .section-title {
    margin-top: 0;
  }

  .community-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: 1.75rem;
  }

  .roles-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .role-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 1.1rem;
  }

  .role-icon {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
    background-color: var(--brand-maroon-muted);
    border: 1px solid hsl(5, 35%, 82%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-maroon);
    flex-shrink: 0;
  }

  .role-text h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .role-text p {
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  .community-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .link-card {
    padding: 1.35rem;
  }

  .link-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.65rem;
  }

  .link-card p {
    font-size: 0.875rem;
    line-height: 1.55;
    margin-bottom: 1rem;
  }

  .link-card .btn {
    width: 100%;
  }

  @media (max-width: 968px) {
    .community-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
