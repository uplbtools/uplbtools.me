---
---
<section id="community" class="section community-section">
  <div class="container">
    <div class="community-grid">
      <div class="community-intro">
        <span class="badge badge-maroon">Join the Initiative</span>
        <h2 class="section-title">The Perfect <span class="gradient-text-maroon">Training Ground</span></h2>
        <p class="community-desc">
          uplb.tools isn't just about building software—it's a hands-on learning community. We guide you through the process of shipping real-world projects. No prior experience is required; we teach and learn as we go!
        </p>
        
        <div class="roles-list">
          <div class="role-item">
            <div class="role-dot dot-red"></div>
            <div class="role-text">
              <h4>For Developers</h4>
              <p>Work with Astro, React, browser extension APIs, Mapbox, and modern deployment pipelines. Master version control with Git.</p>
            </div>
          </div>
          
          <div class="role-item">
            <div class="role-dot dot-green"></div>
            <div class="role-text">
              <h4>For UX/UI Designers</h4>
              <p>Craft user interfaces in Figma, map out user experience flows, build design systems, and witness your designs come to life.</p>
            </div>
          </div>
          
          <div class="role-item">
            <div class="role-dot dot-red"></div>
            <div class="role-text">
              <h4>For Creatives & Writers</h4>
              <p>Write clean user documentation, create guides, draft project proposals, manage outreach, and tell our stories.</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="community-links">
        <div class="card community-link-card highlight-github">
          <div class="link-card-header">
            <div class="link-icon-bg">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
            </div>
            <div>
              <h3>GitHub Organization</h3>
              <p class="status-badge live">Live & Active</p>
            </div>
          </div>
          <p class="link-card-body">
            Browse our code bases, report bugs, pick up open issues, or start a new repository under our organization.
          </p>
          <a href="https://github.com/uplbtools" target="_blank" rel="noopener noreferrer" class="btn btn-primary w-full">
            <span>Explore Github Org</span>
          </a>
        </div>

        <div class="card community-link-card">
          <div class="link-card-header">
            <div class="link-icon-bg bg-discord">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </div>
            <div>
              <h3>Discord Community</h3>
              <p class="status-badge tba">TBA (Coming Soon)</p>
            </div>
          </div>
          <p class="link-card-body">
            Discuss projects, share ideas, receive feedback, and collaborate with student developers and designers.
          </p>
          <button class="btn btn-secondary w-full" disabled>
            <span>TBA</span>
          </button>
        </div>

        <div class="card community-link-card">
          <div class="link-card-header">
            <div class="link-icon-bg bg-messenger">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
            </div>
            <div>
              <h3>Messenger Group</h3>
              <p class="status-badge tba">TBA (Coming Soon)</p>
            </div>
          </div>
          <p class="link-card-body">
            Keep in touch, coordinate quick meets, and join informal community chats on the go.
          </p>
          <button class="btn btn-secondary w-full" disabled>
            <span>TBA</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .community-section {
    position: relative;
    border-top: 1px solid var(--border-color);
    background: linear-gradient(180deg, rgba(13, 17, 34, 0.3) 0%, transparent 100%);
  }
  
  .community-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 5rem;
    align-items: flex-start;
  }
  
  .section-title {
    font-size: 2.75rem;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  
  .community-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }
  
  .roles-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .role-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  
  .role-dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 6px;
  }
  
  .role-dot.dot-red {
    background-color: var(--color-maroon);
    box-shadow: 0 0 10px var(--color-maroon-glow);
  }
  
  .role-dot.dot-green {
    background-color: var(--color-green);
    box-shadow: 0 0 10px var(--color-green-glow);
  }
  
  .role-text h4 {
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
    font-weight: 600;
  }
  
  .role-text p {
    font-size: 0.95rem;
    line-height: 1.5;
  }
  
  .community-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .community-link-card {
    padding: 1.5rem;
  }
  
  .highlight-github {
    border-color: var(--color-maroon-glow);
    box-shadow: 0 4px 25px rgba(184, 29, 64, 0.05);
  }
  
  .highlight-github:hover {
    border-color: var(--color-maroon);
    box-shadow: 0 8px 30px rgba(184, 29, 64, 0.15);
  }
  
  .link-card-header {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  
  .link-icon-bg {
    width: 42px;
    height: 42px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-primary);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .bg-discord {
    background: rgba(88, 101, 242, 0.1);
    color: #5865f2;
    border-color: rgba(88, 101, 242, 0.2);
  }
  
  .bg-messenger {
    background: rgba(0, 132, 255, 0.1);
    color: #0084ff;
    border-color: rgba(0, 132, 255, 0.2);
  }
  
  .link-card-header h3 {
    font-size: 1.1rem;
    margin: 0;
  }
  
  .status-badge {
    font-size: 0.7rem;
    font-weight: 700;
    margin-top: 2px;
    display: inline-block;
  }
  
  .status-badge.live {
    color: var(--color-green);
  }
  
  .status-badge.tba {
    color: var(--text-muted);
  }
  
  .link-card-body {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }
  
  .w-full {
    width: 100%;
  }
  
  button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  @media (max-width: 968px) {
    .community-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }
</style>
