---
import {
  fetchOrgTopContributors,
  formatGithubContributions,
} from "../lib/github-org-contributors";
import OpensInNewTab from "./OpensInNewTab.astro";

const TOP_CONTRIBUTOR_COUNT = 12;

let contributors: Awaited<ReturnType<typeof fetchOrgTopContributors>> = [];
let loadError: string | null = null;

try {
  contributors = await fetchOrgTopContributors(TOP_CONTRIBUTOR_COUNT);
} catch {
  loadError = "Could not load contributors from GitHub during the last build.";
}
---

<section id="contributors" class="section contributors-section" aria-labelledby="contributors-heading">
  <div class="container">
    <div class="contributors-header">
      <div>
        <h2 id="contributors-heading" class="section-title">Top contributors</h2>
        <p class="section-subtitle">
          Commit history across public <code>uplbtools</code> GitHub repositories.
          Bots and automated accounts are filtered out.
        </p>
      </div>
      <a
        href="https://github.com/uplbtools"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary"
        aria-label="View uplbtools organization on GitHub"
      >
        View org on GitHub
        <OpensInNewTab />
      </a>
    </div>

    {
      loadError ? (
        <p class="contributors-status contributors-status--error" role="alert">
          {loadError}
        </p>
      ) : contributors.length === 0 ? (
        <p class="contributors-status" role="status">
          No public contributors found yet. Check back after the next deploy.
        </p>
      ) : (
        <ul class="contributors-grid">
          {contributors.map((person) => {
            const displayName = person.name ?? person.login;
            const commits = formatGithubContributions(person.contributions);
            return (
              <li>
                <a
                  class="contributor-card card"
                  href={person.profileUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${displayName}, ${commits} across uplbtools repositories on GitHub`}
                >
                  <img
                    src={person.avatarUrl}
                    alt=""
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    class="contributor-card__avatar"
                    aria-hidden="true"
                  />
                  <span class="contributor-card__name">{displayName}</span>
                  {person.name ? (
                    <span class="contributor-card__login">@{person.login}</span>
                  ) : null}
                  <span class="contributor-card__commits">{commits}</span>
                  <OpensInNewTab />
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</section>

<style>
  .contributors-section {
    background: linear-gradient(
      180deg,
      var(--bg-page) 0%,
      hsl(5, 20%, 94%) 100%
    );
  }

  .contributors-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }

  .contributors-header .section-title {
    margin-top: 0;
  }

  .contributors-header code {
    font-size: 0.9em;
    color: var(--brand-maroon);
  }

  .contributors-status {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--text-muted);
  }

  .contributors-status--error {
    color: hsl(0, 55%, 36%);
  }

  .contributors-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(9.5rem, 1fr));
    gap: 0.85rem;
    margin: 0;
    padding: 0;
  }

  .contributor-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1rem 0.75rem;
    gap: 0.25rem;
    min-height: 100%;
  }

  .contributor-card:hover {
    border-color: var(--border-accent);
  }

  .contributor-card__avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid var(--border-subtle);
    margin-bottom: 0.35rem;
  }

  .contributor-card__name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-ink);
    line-height: 1.3;
  }

  .contributor-card__login {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .contributor-card__commits {
    margin-top: 0.15rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--brand-maroon);
  }
</style>
