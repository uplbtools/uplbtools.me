---
import { tools } from "../data/tools";
import OpensInNewTab from "./OpensInNewTab.astro";
---
<section id="tools" class="tools-section" aria-labelledby="tools-heading">
  <div class="container">
    <div class="tools-header">
      <h2 id="tools-heading" class="section-title">Campus tools</h2>
      <p class="section-subtitle">
        Open-source utilities for UPLB students. Pick a tool and go.
      </p>
    </div>

    <div class="tools-grid" role="list">
      {
        tools.map((tool) => (
          <article class="tool-card card" role="listitem">
            <div class="tool-card__preview">
              <img
                src={tool.screenshot}
                alt={tool.screenshotAlt}
                width="640"
                height="400"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="tool-card__body">
              <div class="tool-card__tags" aria-label="Categories">
                {tool.tags.map((tag) => (
                  <span class="badge">{tag}</span>
                ))}
                <span class={`badge badge-${tool.status === "live" ? "green" : "maroon"}`}>
                  {tool.statusLabel}
                </span>
              </div>
              <h3 class="tool-card__title">{tool.name}</h3>
              <p class="tool-card__desc">{tool.description}</p>
              <div class="tool-card__actions">
                <a
                  href={tool.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary btn-sm"
                >
                  {tool.actionLabel}
                  <OpensInNewTab />
                </a>
                {
                  tool.facebookHref ? (
                    <a
                      href={tool.facebookHref}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-secondary btn-sm"
                      aria-label={`${tool.name} on Facebook`}
                    >
                      Facebook
                      <OpensInNewTab />
                    </a>
                  ) : null
                }
                {
                  tool.githubHref ? (
                    <a
                      href={tool.githubHref}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-secondary btn-sm"
                      aria-label={`${tool.name} source on GitHub`}
                    >
                      GitHub
                      <OpensInNewTab />
                    </a>
                  ) : null
                }
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tools-section {
    padding: 1.25rem 0 4rem;
    border-bottom: 1px solid var(--border-subtle);
  }

  .tools-header {
    margin-bottom: 1.5rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
    list-style: none;
    padding: 0;
    margin-top: 0;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
  }

  .tool-card__preview {
    border-bottom: 1px solid var(--border-subtle);
    background: var(--bg-panel);
    overflow: hidden;
  }

  .tool-card__preview img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .tool-card:hover .tool-card__preview img {
    transform: scale(1.02);
  }

  .tool-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem;
    gap: 0.5rem;
  }

  .tool-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tool-card__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    margin: 0;
  }

  .tool-card__desc {
    font-size: 0.875rem;
    line-height: 1.5;
    flex: 1;
    margin: 0;
  }

  .tool-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .tool-card__preview img {
      transition: none;
    }

    .tool-card:hover .tool-card__preview img {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
