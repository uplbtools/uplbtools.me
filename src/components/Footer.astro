---
---
<footer class="main-footer">
  <div class="container footer-container">
    <div class="footer-brand-side">
      <a href="#" class="logo">
        uplb<span class="logo-dot">.</span><span class="logo-tools">tools</span>
      </a>
      <p class="brand-pitch">
        Building open-source, privacy-preserving utility applications for the student community of the University of the Philippines Los Baños.
      </p>
    </div>
    
    <div class="footer-links-side">
      <div class="footer-nav">
        <h4>Navigation</h4>
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#community">Community</a>
      </div>
      
      <div class="footer-socials">
        <h4>Resources</h4>
        <a href="https://github.com/uplbtools" target="_blank" rel="noopener noreferrer">GitHub Organization</a>
        <a href="https://github.com/uplbtools/uplbtools.me" target="_blank" rel="noopener noreferrer">Website Source</a>
      </div>
    </div>
  </div>
  
  <div class="container footer-bottom">
    <div class="disclaimer">
      <p>Disclaimer: uplb.tools is an independent student-led open-source project. We are not officially affiliated with, endorsed by, or representing the University of the Philippines Los Baños (UPLB) administration.</p>
    </div>
    <div class="copyright">
      <p>&copy; {new Date().getFullYear()} uplb.tools. Built by Elbi Student Developers.</p>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    border-top: 1px solid var(--border-subtle);
    background-color: #06070a;
    padding-top: 5rem;
    padding-bottom: 3rem;
  }
  
  .footer-container {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    margin-bottom: 4rem;
  }
  
  .footer-brand-side {
    max-width: 380px;
  }
  
  .logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    color: var(--text-title);
    margin-bottom: 1rem;
    display: block;
  }
  
  .logo-dot {
    color: var(--brand-maroon-light);
  }
  
  .logo-tools {
    color: var(--brand-green-light);
    font-weight: 500;
  }
  
  .brand-pitch {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-body);
  }
  
  .footer-links-side {
    display: flex;
    gap: 5rem;
  }
  
  .footer-nav, .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .footer-nav h4, .footer-socials h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
  }
  
  .footer-nav a, .footer-socials a {
    font-size: 0.875rem;
    color: var(--text-body);
    text-decoration: none;
    transition: var(--transition-fast);
  }
  
  .footer-nav a:hover, .footer-socials a:hover {
    color: var(--text-title);
  }
  
  .footer-bottom {
    border-top: 1px solid var(--border-subtle);
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: center;
    text-align: center;
  }
  
  .disclaimer {
    max-width: 800px;
  }
  
  .disclaimer p {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  
  .copyright p {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  
  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      gap: 3rem;
    }
    
    .footer-links-side {
      gap: 4rem;
    }
  }
</style>
