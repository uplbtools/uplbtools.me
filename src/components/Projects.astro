---
---
<section id="projects" class="section projects-section">
  <div class="container">
    <div class="section-header">
      <span class="badge badge-green">Our Projects</span>
      <h2 class="section-title-center">Useful Software For <span class="gradient-text-maroon">UPLB Students</span></h2>
      <p class="section-subtitle-center">
        We identify student pain points and engineer solutions. Both tools are open-source, privacy-focused, and free to use.
      </p>
    </div>
    
    <div class="projects-grid">
      <!-- Project 1: Room TBA -->
      <div class="card project-card">
        <div class="project-browser-frame">
          <div class="browser-header">
            <div class="browser-dots">
              <span class="b-dot"></span>
              <span class="b-dot"></span>
              <span class="b-dot"></span>
            </div>
            <div class="browser-address">room-tba.uplbtools.me</div>
          </div>
          <div class="browser-body">
            <img src="/room-tba-screenshot.png" alt="Room TBA Screenshot" class="project-screenshot" />
          </div>
        </div>
        
        <div class="project-info">
          <div class="project-tags">
            <span class="tag tag-maroon">Interactive Map</span>
            <span class="tag">Open Source</span>
            <span class="tag">3D Render</span>
          </div>
          <h3 class="project-title">Room TBA</h3>
          <p class="project-desc">
            An interactive 3D map of the UPLB campus built to help students locate classrooms, divisions, dorms, and colleges. Features live jeepney route overlays and classroom schedules to optimize navigation.
          </p>
          <div class="project-actions">
            <a href="https://room-tba.uplbtools.me" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
              <span>Launch App</span>
              <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
            <a href="https://github.com/uplbtools" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">
              <span>Source Code</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Project 2: GradeSim -->
      <div class="card project-card">
        <div class="project-browser-frame">
          <div class="browser-header">
            <div class="browser-dots">
              <span class="b-dot"></span>
              <span class="b-dot"></span>
              <span class="b-dot"></span>
            </div>
            <div class="browser-address">gradesim.uplbtools.me</div>
          </div>
          <div class="browser-body">
            <img src="/gradesim-screenshot.png" alt="GradeSim Screenshot" class="project-screenshot" />
          </div>
        </div>
        
        <div class="project-info">
          <div class="project-tags">
            <span class="tag tag-green">Browser Extension</span>
            <span class="tag">Calculator</span>
            <span class="tag">GWA Tools</span>
          </div>
          <h3 class="project-title">Elbi GradeSim</h3>
          <p class="project-desc">
            A GWA calculator and Latin honor simulator browser extension that integrates directly with the UPLB AMIS portal. Simulates grade targets and lists semester achievements without sending data off-device.
          </p>
          <div class="project-actions">
            <a href="https://gradesim.uplbtools.me" target="_blank" rel="noopener noreferrer" class="btn btn-green btn-sm">
              <span>Install Extension</span>
              <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
            <a href="https://github.com/uplbtools" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">
              <span>Source Code</span>
            </a>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Future Tool Teaser Banner -->
    <div class="card future-teaser-card">
      <div class="teaser-glow"></div>
      <div class="teaser-content">
        <div class="teaser-badge">
          <span class="pulse-dot green"></span>
          <span>More in Development</span>
        </div>
        <h3>Have an idea that could help Elbi students?</h3>
        <p>We are always brainstorming new tools—from schedule organizers to enlistment helpers. If you have an idea or want to build one under the uplb.tools organization, we want to hear from you!</p>
        <a href="#community" class="btn btn-secondary btn-teaser">
          <span>Pitch Your Project Idea</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .projects-section {
    position: relative;
    border-top: 1px solid var(--border-color);
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .section-title-center {
    font-size: 2.75rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  
  .section-subtitle-center {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 3rem;
    margin-bottom: 4rem;
  }
  
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    height: 100%;
  }
  
  .project-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .project-card:hover .project-screenshot {
    transform: scale(1.03);
  }
  
  .project-browser-frame {
    background: #0d1117;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  
  .browser-header {
    height: 36px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    padding: 0 1rem;
    gap: 1.5rem;
    position: relative;
  }
  
  .browser-dots {
    display: flex;
    gap: 6px;
  }
  
  .b-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
  }
  
  .browser-address {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-display);
    background: rgba(0, 0, 0, 0.3);
    padding: 3px 20px;
    border-radius: 4px;
    width: max-content;
    max-width: 220px;
    margin: 0 auto;
    text-align: center;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  
  .browser-body {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #090d16;
  }
  
  .project-screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }
  
  .project-info {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  
  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  
  .tag {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  
  .tag-maroon {
    background: rgba(184, 29, 64, 0.1);
    border-color: rgba(184, 29, 64, 0.2);
    color: #ff5e83;
  }
  
  .tag-green {
    background: rgba(16, 185, 129, 0.1);
    border-color: rgba(16, 185, 129, 0.2);
    color: #34d399;
  }
  
  .project-title {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .project-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    flex-grow: 1;
  }
  
  .project-actions {
    display: flex;
    gap: 1rem;
  }

  .btn-sm {
    padding: 0.6rem 1.25rem;
    font-size: 0.85rem;
  }
  
  /* Future teaser card */
  .future-teaser-card {
    position: relative;
    padding: 3rem;
    text-align: center;
    overflow: hidden;
    margin-top: 2rem;
  }
  
  .teaser-glow {
    position: absolute;
    inset: -50%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 60%);
    filter: blur(45px);
    z-index: 1;
    pointer-events: none;
  }
  
  .teaser-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .teaser-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #34d399;
    background: rgba(16, 185, 129, 0.08);
    padding: 4px 12px;
    border-radius: 9999px;
    border: 1px solid rgba(16, 185, 129, 0.2);
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .future-teaser-card h3 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  
  .future-teaser-card p {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  
  .btn-teaser {
    margin-top: 0.5rem;
  }
  
  @media (max-width: 968px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    
    .future-teaser-card {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
