---
---
<section id="projects" class="section projects-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Active Projects</h2>
      <p class="section-subtitle">
        Below are the primary tools developed and maintained by the collective.
      </p>
    </div>
    
    <div class="projects-grid">
      <!-- Project: Room TBA -->
      <div class="card project-card">
        <div class="project-preview">
          <img src="/room-tba-screenshot.png" alt="Room TBA Search Utility" class="preview-img" />
        </div>
        
        <div class="project-meta">
          <div class="meta-tags">
            <span class="badge badge-maroon">Interactive Map</span>
            <span class="badge">Next.js</span>
            <span class="badge">Mapbox GL</span>
          </div>
          <h3>Room TBA</h3>
          <p class="project-desc">
            A utility map that helps UPLB students look up room schedules, navigate between class buildings, and view jeepney routes around the campus.
          </p>
          <div class="meta-actions">
            <a href="https://room-tba.uplbtools.me" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">Launch App</a>
            <a href="https://github.com/uplbtools" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">GitHub</a>
          </div>
        </div>
      </div>

      <!-- Project: GradeSim -->
      <div class="card project-card">
        <div class="project-preview">
          <img src="/gradesim-screenshot.png" alt="GradeSim AMIS Extension" class="preview-img" />
        </div>
        
        <div class="project-meta">
          <div class="meta-tags">
            <span class="badge badge-green">Browser Extension</span>
            <span class="badge">GWA Calc</span>
            <span class="badge">JavaScript</span>
          </div>
          <h3>Elbi GradeSim</h3>
          <p class="project-desc">
            A lightweight GWA simulation browser extension that overlays on the UPLB AMIS grades portal to calculate and model target graduation honor requirements.
          </p>
          <div class="meta-actions">
            <a href="https://gradesim.uplbtools.me" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">Install Extension</a>
            <a href="https://github.com/uplbtools" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">GitHub</a>
          </div>
        </div>
      </div>
    </div>
    
    <div class="pitch-container">
      <div class="pitch-card">
        <div class="pitch-text">
          <h3>Have an idea for a student utility?</h3>
          <p>We host and help maintain tools built by UPLB students. If you have a script, an extension, or a static page that benefits the campus community, reach out to join our GitHub organization.</p>
        </div>
        <div class="pitch-action">
          <a href="#community" class="btn btn-secondary">Get in Touch</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: 3rem;
  }
  
  .section-title {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }
  
  .section-subtitle {
    font-size: 0.925rem;
    color: var(--text-zinc-400);
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .project-card {
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  .project-preview {
    background-color: #0c0c0e;
    border-bottom: 1px solid var(--border-zinc);
    overflow: hidden;
  }
  
  .preview-img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    display: block;
  }
  
  .project-meta {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  
  .meta-tags {
    display: flex;
    gap: 0.35rem;
    margin-bottom: 0.85rem;
    flex-wrap: wrap;
  }
  
  .project-meta h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }
  
  .project-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-zinc-400);
    margin-bottom: 1.25rem;
    flex-grow: 1;
  }
  
  .meta-actions {
    display: flex;
    gap: 0.5rem;
  }
  
  .btn-sm {
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    border-radius: 4px;
  }
  
  .pitch-container {
    margin-top: 1.5rem;
  }
  
  .pitch-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border: 1px solid var(--border-zinc);
    border-radius: 8px;
    gap: 2rem;
  }
  
  .pitch-text h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  
  .pitch-text p {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-zinc-400);
  }
  
  .pitch-action {
    flex-shrink: 0;
  }
  
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    
    .pitch-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }
</style>
