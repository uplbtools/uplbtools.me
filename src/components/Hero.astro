---
---
<section class="hero-section">
  <div class="container hero-container">
    <div class="hero-content">
      <div class="hero-badge-container">
        <span class="badge badge-maroon">Student Organization</span>
        <span class="badge badge-green">Open Source</span>
      </div>
      <h1 class="hero-title">
        Building useful utilities <br/>
        for <span class="accent-maroon">UP Los Baños</span>
      </h1>
      <p class="hero-subtitle">
        We are an independent, open-source initiative creating custom, privacy-first software to streamline student workflows at UPLB. We also provide a collaborative training sandbox for student developers, designers, and creatives.
      </p>
      
      <div class="hero-ctas">
        <a href="#projects" class="btn btn-primary">
          <span>Explore Tools</span>
        </a>
        <a href="#community" class="btn btn-secondary">
          <span>Join the Initiative</span>
        </a>
      </div>
    </div>
    
    <div class="hero-visual">
      <div class="visual-wrapper">
        <div class="mockup-frame">
          <div class="frame-header">
            <div class="dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
            <div class="address-bar">github.com/uplbtools</div>
          </div>
          <div class="frame-body">
            <img src="/github-org-screenshot.png" alt="uplbtools GitHub Organization" class="mockup-img" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: 9rem;
    padding-bottom: 7rem;
    display: flex;
    align-items: center;
    position: relative;
    border-bottom: 1px solid var(--border-subtle);
  }
  
  .hero-container {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 4rem;
  }
  
  .hero-badge-container {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  
  .hero-title {
    font-size: 3rem;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    font-weight: 800;
  }
  
  .accent-maroon {
    color: var(--text-title);
    border-bottom: 3px solid var(--brand-maroon-light);
  }
  
  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-body);
    line-height: 1.6;
    margin-bottom: 2.25rem;
  }
  
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
  }
  
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .visual-wrapper {
    width: 100%;
    max-width: 480px;
  }
  
  .mockup-frame {
    background-color: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  
  .frame-header {
    height: 34px;
    background-color: #0d0e14;
    border-bottom: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    padding: 0 1rem;
    position: relative;
  }
  
  .dots {
    display: flex;
    gap: 5px;
  }
  
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--border-subtle);
  }
  
  .address-bar {
    font-size: 0.75rem;
    color: var(--text-body);
    font-family: var(--font-sans);
    background-color: var(--bg-main);
    padding: 3px 16px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-subtle);
    width: 180px;
    text-align: center;
    margin: 0 auto;
  }
  
  .frame-body {
    background-color: #090a0f;
    padding: 6px;
  }
  
  .mockup-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-md);
  }
  
  @media (max-width: 968px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3.5rem;
    }
    
    .hero-badge-container {
      justify-content: center;
    }
    
    .hero-subtitle {
      max-width: 600px;
      margin: 0 auto 2.25rem;
    }
    
    .hero-ctas {
      justify-content: center;
    }
    
    .hero-visual {
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2.25rem;
    }
  }
</style>
