---
import OpensInNewTab from "./OpensInNewTab.astro";

const quickLinks = [
  {
    label: "Discord",
    href: "https://discord.uplbtools.me",
    icon: "/brand/discord.svg",
  },
  {
    label: "Messenger GC",
    href: "https://messenger.uplbtools.me",
    icon: "/brand/messenger.svg",
  },
];
---
<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-backdrop" aria-hidden="true"></div>
  <div class="container hero-container">
    <div class="hero-copy">
      <h1 id="hero-title" class="hero-title">
        Useful utilities built for{" "}
        <span class="hero-title__place">UP Los Baños</span>
      </h1>
      <p class="hero-description">
        Lightweight, privacy-first open-source tools for the UPLB community.
      </p>
      <nav class="hero-actions" aria-label="Community links">
        {
          quickLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-secondary"
            >
              <img
                src={link.icon}
                alt=""
                width="16"
                height="16"
                class="hero-link-icon"
                decoding="async"
                aria-hidden="true"
              />
              <span>{link.label}</span>
              <OpensInNewTab />
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    z-index: 0;
    margin-top: var(--header-height);
    padding: 0.75rem 0 1rem;
    overflow: hidden;
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url("/uplb-bg.webp");
    background-size: cover;
    background-position: center;
  }

  .hero-backdrop::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      hsla(5, 55%, 32%, 0.92) 0%,
      hsla(5, 45%, 24%, 0.88) 55%,
      hsla(5, 30%, 18%, 0.9) 100%
    );
  }

  .hero-container {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    max-width: 40rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 4vw, 2.75rem);
    line-height: 1.12;
    margin-bottom: 0.85rem;
    color: var(--text-on-maroon);
    text-wrap: balance;
  }

  .hero-title__place {
    white-space: nowrap;
  }

  .hero-description {
    font-size: 1rem;
    line-height: 1.6;
    color: hsl(0, 0%, 100%);
    margin-bottom: 1.5rem;
    max-width: 36rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .hero-link-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    display: block;
  }

  .hero-actions .btn-secondary {
    background: hsla(0, 0%, 100%, 0.1);
    border-color: hsla(0, 0%, 100%, 0.28);
    color: var(--text-on-maroon);
  }

  .hero-actions .btn-secondary:hover {
    background: hsla(0, 0%, 100%, 0.18);
    border-color: hsla(0, 0%, 100%, 0.45);
  }

  .hero-actions .btn-secondary:focus-visible {
    outline-color: hsl(0, 0%, 100%);
    outline-width: 3px;
  }
</style>
