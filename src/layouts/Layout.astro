---
import '../styles/global.css';

interface Props {
 title?: string;
 description?: string;
}

const {
 title = "uplb.tools | Open Source for UP Los Baños",
 description = "An open-source initiative building utility tools for UPLB students and providing a creative training ground for developers, designers, and innovators."
} = Astro.props;
---

<!doctype html>
<html lang="en">
 <head>
 <meta charset="UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0" />
 <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
 <link rel="icon" href="/favicon.ico" sizes="48x48" />
 <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
 <meta name="generator" content={Astro.generator} />

 <!-- <!, Primary SEO Meta Tags, > -->
 <title>{title}</title>
 <meta name="title" content={title} />
 <meta name="description" content={description} />

 <!-- <!, Open Graph / Facebook, > -->
 <meta property="og:type" content="website" />
 <meta property="og:url" content="https://uplbtools.me/" />
 <meta property="og:title" content={title} />
 <meta property="og:description" content={description} />
 <meta property="og:image" content="/github-org-screenshot.png" />

 <!-- <!, Twitter, > -->
 <meta property="twitter:card" content="summary_large_image" />
 <meta property="twitter:url" content="https://uplbtools.me/" />
 <meta property="twitter:title" content={title} />
 <meta property="twitter:description" content={description} />
 <meta property="twitter:image" content="/github-org-screenshot.png" />

 <link rel="canonical" href="https://uplbtools.me/" />
 </head>
 <body>
 <!-- <!, Header and Content Slot, > -->
 <slot />
 </body>
</html>
